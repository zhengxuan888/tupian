{
  "appId": "com.ai-image-processor.app",
  "productName": "AI 图片处理器",
  "copyright": "Copyright © 2026",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "out/**/*",
    "electron/**/*",
    "public/app-icon.jpg"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "public/app-icon.jpg"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "AI 图片处理器",
    "installerIcon": "public/app-icon.jpg",
    "uninstallerIcon": "public/app-icon.jpg"
  },
  "mac": {
    "target": ["dmg"],
    "icon": "public/app-icon.jpg"
  },
  "linux": {
    "target": ["AppImage"],
    "icon": "public/app-icon.jpg"
  }
}
